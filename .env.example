# Application
APP_ENV=development
SECRET_KEY=change-this-to-a-long-random-secret-key-in-production
APP_TITLE=DPRP Cash Call Automation System

# Database
DATABASE_URL=sqlite:///./cashcall.db
# Production: DATABASE_URL=postgresql+psycopg2://user:password@host:5432/cashcall

# Azure AD (required in production, ignored in development)
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
AZURE_REDIRECT_URI=http://localhost:8000/auth/callback

# Dev bypass login (only active when APP_ENV=development)
DEV_BYPASS_ENABLED=true

# Email (Phase 4+)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=cashcall@dangote.com

# Session
SESSION_MAX_AGE_SECONDS=28800
