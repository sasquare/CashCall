# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=production                      # development | production
APP_TITLE=DPRP Cash Call Automation System

# REQUIRED in production — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_generate_a_32_byte_hex_secret

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (single-server / development):
DATABASE_URL=sqlite:////data/cashcall.db

# PostgreSQL (recommended for production):
# DATABASE_URL=postgresql+psycopg2://cashcall:PASSWORD@db:5432/cashcall

# ── Azure AD (Microsoft SSO) ──────────────────────────────────────────────────
# Leave blank to disable SSO (shows dev-bypass form only).
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
AZURE_REDIRECT_URI=https://your-domain/auth/callback

# ── Developer bypass ──────────────────────────────────────────────────────────
# Must be false in production.
DEV_BYPASS_ENABLED=false

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=cashcall@dangote.com
SMTP_PASSWORD=
EMAIL_FROM=cashcall@dangote.com

# ── Session ───────────────────────────────────────────────────────────────────
SESSION_MAX_AGE_SECONDS=28800           # 8 hours

# ── PostgreSQL (used by docker-compose.prod.yml) ──────────────────────────────
POSTGRES_DB=cashcall
POSTGRES_USER=cashcall
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password

# ── Runtime tuning ────────────────────────────────────────────────────────────
WORKERS=2
PORT=8000
SEED_DB=false                           # set true on first dev run to load seed data
